# Copy this file to .env and fill in your values
# .env is git-ignored and must never be committed

# OpenAI backend
OPENAI_API_KEY=

# Anthropic/Claude backend
ANTHROPIC_API_KEY=

# Ollama (local, no key required)
ARIA_OLLAMA_HOST=http://localhost:11434
ARIA_OLLAMA_MODEL=gemma3:4b

# Optional overrides
ARIA_LLM_BACKEND=openai         # openai | ollama | claude
ARIA_CHAT_MODEL=gpt-4.1-mini
ARIA_CLAUDE_MODEL=claude-opus-4-6
ARIA_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
ARIA_MAX_FILES=                 # leave empty for no limit
ARIA_MIN_ALPHA_RATIO=0.55
